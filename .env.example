# Copy to .env and fill in from your Supabase project (Project Settings → API).
# Until both are set, the site runs on bundled default content and the admin
# shows a "not configured" notice.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Paystack public key (Dashboard → Settings → API Keys & Webhooks).
# When set, the donate widget opens Paystack checkout; until then it shows a
# confirmation without charging. Use the pk_test_… key while developing.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_YOUR-PUBLIC-KEY

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY — these are NOT read by the browser (no VITE_ prefix). They
# power the `paystack-webhook` Supabase Edge Function that emails a receipt when
# a donation succeeds. Do NOT expose them in the frontend. Set them on Supabase
# with:  supabase secrets set PAYSTACK_SECRET_KEY=… RESEND_API_KEY=… DONATION_FROM_EMAIL=…
PAYSTACK_SECRET_KEY=sk_test_YOUR-SECRET-KEY
RESEND_API_KEY=re_YOUR-RESEND-KEY
DONATION_FROM_EMAIL=AACF <giving@your-domain.org>

